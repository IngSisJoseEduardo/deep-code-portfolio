---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  title: string;
}

const { images, title } = Astro.props;

if (images.length === 0) return;

// Pre-genera URLs optimizadas full-size para el modal (no renderiza <img>)
const fullSizeUrls = await Promise.all(
  images.map((img) =>
    getImage({ src: img, width: 1400, format: 'webp', quality: 88 }).then((r) => r.src)
  )
);

const visibleThumbs = images.slice(0, 4);
const extraCount = images.length - 4;
---

<div class="gallery-wrapper">
  <!-- Grid 2×2 de thumbnails -->
  <div class="grid grid-cols-2 gap-3">
    {visibleThumbs.map((img, i) => (
      <button
        type="button"
        class="gallery-thumb group relative overflow-hidden rounded-xl bg-surface-container aspect-video cursor-zoom-in"
        data-index={i}
        aria-label={`Ver imagen ${i + 1} de ${images.length}`}
      >
        <Image
          src={img}
          alt={`${title} — captura ${i + 1}`}
          class="w-full h-full object-cover opacity-75 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
          loading="lazy"
          decoding="async"
          widths={[400, 700]}
          sizes="(max-width: 768px) 50vw, 380px"
        />

        <!-- Overlay "+N más" en el último thumbnail si hay extras -->
        {i === 3 && extraCount > 0 && (
          <div class="absolute inset-0 bg-black/65 flex flex-col items-center justify-center gap-1 rounded-xl">
            <span class="text-white font-bold text-3xl leading-none">+{extraCount}</span>
            <span class="text-white/70 text-xs font-medium tracking-wider uppercase">más fotos</span>
          </div>
        )}

        <!-- Icono zoom en hover -->
        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
          <span class="material-symbols-outlined text-white drop-shadow-lg" style="font-size:2rem">zoom_in</span>
        </div>
      </button>
    ))}
  </div>
</div>

<!-- Modal / Lightbox -->
<dialog id="gallery-dialog" aria-label={`Galería de ${title}`}>
  <div id="dialog-backdrop" class="fixed inset-0 flex items-center justify-center">

    <!-- Botón cerrar -->
    <button id="dialog-close" type="button" aria-label="Cerrar galería"
      class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors bg-black/30 hover:bg-black/60 rounded-full p-2">
      <span class="material-symbols-outlined" style="font-size:1.5rem">close</span>
    </button>

    <!-- Contador -->
    <p id="dialog-counter" class="absolute top-5 left-1/2 -translate-x-1/2 z-10 text-white/50 text-sm font-medium tabular-nums">
      1 / {images.length}
    </p>

    <!-- Prev -->
    <button id="dialog-prev" type="button" aria-label="Imagen anterior"
      class="absolute left-3 md:left-6 z-10 text-white/70 hover:text-white transition-colors bg-black/30 hover:bg-black/60 rounded-full p-2 md:p-3">
      <span class="material-symbols-outlined" style="font-size:1.75rem">chevron_left</span>
    </button>

    <!-- Imagen principal -->
    <div class="w-full h-full flex items-center justify-center px-16 md:px-24 py-16">
      <img
        id="dialog-img"
        src=""
        alt=""
        class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl select-none"
        draggable="false"
      />
    </div>

    <!-- Next -->
    <button id="dialog-next" type="button" aria-label="Imagen siguiente"
      class="absolute right-3 md:right-6 z-10 text-white/70 hover:text-white transition-colors bg-black/30 hover:bg-black/60 rounded-full p-2 md:p-3">
      <span class="material-symbols-outlined" style="font-size:1.75rem">chevron_right</span>
    </button>
  </div>
</dialog>

<style>
  /* Reset del <dialog> nativo */
  dialog {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    overflow: hidden;
  }
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  /* Animación de entrada */
  dialog[open] {
    animation: fade-in 0.2s ease;
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .material-symbols-outlined {
    font-family: 'Material Symbols Outlined';
    font-weight: normal;
    font-style: normal;
    display: inline-block;
    line-height: 1;
    text-transform: none;
    letter-spacing: normal;
    word-wrap: normal;
    white-space: nowrap;
  }
</style>

<script define:vars={{ fullSizeUrls, totalImages: images.length, projectTitle: title }}>
  const dialog  = document.getElementById('gallery-dialog');
  const imgEl   = document.getElementById('dialog-img');
  const counter = document.getElementById('dialog-counter');
  const thumbs  = document.querySelectorAll('.gallery-thumb');

  let current = 0;

  function open(index) {
    current = index;
    render();
    dialog.showModal();
    document.body.style.overflow = 'hidden';
  }

  function close() {
    dialog.close();
    document.body.style.overflow = '';
  }

  function render() {
    imgEl.src = fullSizeUrls[current];
    imgEl.alt = `${projectTitle} — captura ${current + 1}`;
    counter.textContent = `${current + 1} / ${totalImages}`;
  }

  function next() { current = (current + 1) % totalImages; render(); }
  function prev() { current = (current - 1 + totalImages) % totalImages; render(); }

  // Abrir desde thumbnail
  thumbs.forEach((btn) => {
    btn.addEventListener('click', () => open(Number(btn.dataset.index)));
  });

  document.getElementById('dialog-close').addEventListener('click', close);
  document.getElementById('dialog-next').addEventListener('click', next);
  document.getElementById('dialog-prev').addEventListener('click', prev);

  // Clic en el backdrop (fondo) cierra el modal
  document.getElementById('dialog-backdrop').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) close();
  });

  // Teclado
  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') next();
    else if (e.key === 'ArrowLeft') prev();
    else if (e.key === 'Escape') close();
  });

  // Swipe en móvil
  let touchStartX = 0;
  imgEl.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  imgEl.addEventListener('touchend', (e) => {
    const delta = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(delta) > 50) delta > 0 ? next() : prev();
  }, { passive: true });
</script>
