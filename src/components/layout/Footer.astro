    <p class="text-on-surface-variant text-sm">
      &copy; {year} José Eduardo Martínez Pérez. Construido con Astro &amp; Tailwind.
    </p>

    <div class="flex items-center gap-6">
      <a
        href="https://github.com/IngSisJoseEduardo"
        target="_blank"
        rel="noopener noreferrer"
        class="text-on-surface-variant hover:text-on-surface text-sm transition-colors duration-300"
      >
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/jos%C3%A9-eduardo-mart%C3%ADnez-p%C3%A9rez-5694a0172/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-on-surface-variant hover:text-on-surface text-sm transition-colors duration-300"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/IngSisJoseEduardo/deep-code-portfolio"
        target="_blank"
        rel="noopener noreferrer"
